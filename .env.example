# Copy this file to ".env.local" and fill in the values.

# --- AI chatbot (Groq) ---
# SECRET, server-side only (no VITE_ prefix → never shipped to the browser).
# Get a FREE key at https://console.groq.com/keys
GROQ_API_KEY=

# --- Live presence (Supabase Realtime) ---
# PUBLIC values, safe in the browser (the anon key is protected by RLS).
# Create a free project at https://supabase.com → Project Settings → API.
# Leave blank to run the site without realtime (shows "it's just you").
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
